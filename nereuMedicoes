"""
SIENGE - EXTRAÇÃO DE MEDIÇÕES DE CONTRATOS
Extrai medições de contratos de fornecimento por obra
"""

import base64
import json
import time
from datetime import datetime
from pathlib import Path
from typing import Optional, Tuple, List

import pandas as pd
import requests


DEFAULT_CREDENTIALS_FILE = Path(__file__).with_name('sienge_credentials.json')


def carregar_credenciais(credentials_path: Optional[str] = None) -> Tuple[Optional[str], Optional[str]]:
    """Carrega credenciais do arquivo JSON"""
    path = Path(credentials_path) if credentials_path else DEFAULT_CREDENTIALS_FILE
    if path.exists():
        try:
            data = json.loads(path.read_text(encoding='utf-8'))
            return data.get('username'), data.get('password')
        except json.JSONDecodeError as exc:
            print(f'Erro ao ler credenciais: {exc}')
            return None, None
    return None, None


class SiengeMedicoesExtractor:
    """Extrator de medições de contratos do Sienge"""
    
    def __init__(self, username: str, password: str):
        self.username = username
        self.password = password
        self.base_url = 'https://api.sienge.com.br/trust/public/api'
        
        credentials = f"{username}:{password}"
        encoded = base64.b64encode(credentials.encode('utf-8')).decode('ascii')
        
        self.headers = {
            'Authorization': f'Basic {encoded}',
            'Content-Type': 'application/json',
            'Accept': 'application/json',
        }
    
    def _fazer_requisicao(self, url: str, params: dict = None, max_tentativas: int = 3) -> dict:
        """Faz requisição HTTP com retry logic"""
        for tentativa in range(max_tentativas):
            try:
                response = requests.get(url, headers=self.headers, params=params, timeout=30)
                if response.status_code == 200:
                    return response.json()
                elif response.status_code == 429:
                    print("    ⚠ Rate limit - aguardando 60s...")
                    time.sleep(60)
                else:
                    if tentativa < max_tentativas - 1:
                        time.sleep(5)
            except requests.exceptions.RequestException:
                if tentativa < max_tentativas - 1:
                    time.sleep(5)
        return {}
    
    def listar_obras(self) -> pd.DataFrame:
        """Lista obras disponíveis"""
        url = f"{self.base_url}/v1/enterprises"
        params = {'limit': 200, 'offset': 0}
        
        todas_obras = []
        offset = 0
        
        while True:
            params['offset'] = offset
            dados = self._fazer_requisicao(url, params)
            
            if not dados:
                break
            
            results = dados.get('results', [])
            if not results:
                break
            
            todas_obras.extend(results)
            
            if len(results) < params['limit']:
                break
            
            offset += len(results)
            time.sleep(0.3)
        
        if not todas_obras:
            return pd.DataFrame()
        
        df = pd.DataFrame(todas_obras)
        df = df.rename(columns={'id': 'buildingId', 'name': 'buildingName'})
        
        return df[['buildingId', 'buildingName']].sort_values('buildingName')
    
    def extrair_medicoes_obra(
        self,
        building_id: int,
        building_name: str,
        data_inicio: str = "2025-01-01",
        data_fim: str = "2026-12-31",
        autorizacao: str = "A",
        consistencia: str = "S"
    ) -> pd.DataFrame:
        """
        Extrai medições de contratos para uma obra específica
        
        Parâmetros:
        - buildingId: ID da obra
        - measurementStartDate/measurementEndDate: período da medição
        - authorization: A (Autorizado), P (Pendente), T (Todas)
        - consistency: S (Consistente), N (Não consistente), T (Todas)
        """
        
        url = f"{self.base_url}/v1/supply-contracts/measurements/all"
        
        params = {
            'buildingId': building_id,
            'measurementStartDate': data_inicio,
            'measurementEndDate': data_fim,
            'authorization': autorizacao,
            'consistency': consistencia,
            'limit': 200,
            'offset': 0
        }
        
        todas_medicoes = []
        offset = 0
        offsets_visitados = set()
        tentativas_vazias = 0
        
        while tentativas_vazias < 3:
            if offset in offsets_visitados:
                break
            
            offsets_visitados.add(offset)
            params['offset'] = offset
            
            dados = self._fazer_requisicao(url, params)
            
            if not dados:
                tentativas_vazias += 1
                offset += 200
                continue
            
            results = dados.get('results', [])
            
            if not results:
                tentativas_vazias += 1
                offset += 200
                continue
            
            # Adicionar identificação da obra
            for medicao in results:
                medicao['buildingId'] = building_id
                medicao['buildingName'] = building_name
            
            todas_medicoes.extend(results)
            tentativas_vazias = 0
            
            if len(results) < params['limit']:
                break
            
            next_offset = dados.get('nextOffset')
            if next_offset is not None and next_offset != offset:
                offset = next_offset
            else:
                offset += len(results)
            
            time.sleep(0.3)
        
        if not todas_medicoes:
            return pd.DataFrame()
        
        return pd.DataFrame(todas_medicoes)
    
    def extrair_medicoes_multiplas_obras(
        self,
        obras_ids: List[int] = None,
        obras_df: pd.DataFrame = None,
        data_inicio: str = "2025-01-01",
        data_fim: str = "2026-12-31",
        autorizacao: str = "A",
        consistencia: str = "S"
    ) -> pd.DataFrame:
        """
        Extrai medições de múltiplas obras
        """
        
        if obras_df is None and obras_ids is None:
            print("  ⚠ Necessário fornecer obras_ids ou obras_df")
            return pd.DataFrame()
        
        # Se recebeu apenas IDs, buscar nomes
        if obras_df is None:
            print("\n  Buscando informações das obras...")
            df_todas_obras = self.listar_obras()
            obras_df = df_todas_obras[df_todas_obras['buildingId'].isin(obras_ids)]
        
        todas_medicoes = []
        total_obras = len(obras_df)
        
        print(f"\n  Extraindo medições de {total_obras} obras...")
        
        for idx, row in obras_df.iterrows():
            building_id = row['buildingId']
            building_name = row['buildingName']
            
            print(f"    [{idx+1}/{total_obras}] {building_name[:50]}...", end=' ')
            
            df_medicoes = self.extrair_medicoes_obra(
                building_id=building_id,
                building_name=building_name,
                data_inicio=data_inicio,
                data_fim=data_fim,
                autorizacao=autorizacao,
                consistencia=consistencia
            )
            
            if df_medicoes.empty:
                print("❌ Sem medições")
            else:
                todas_medicoes.append(df_medicoes)
                print(f"✓ {len(df_medicoes)} medições")
        
        if not todas_medicoes:
            return pd.DataFrame()
        
        return pd.concat(todas_medicoes, ignore_index=True)
    
    def processar_medicoes(self, df: pd.DataFrame) -> pd.DataFrame:
        """Processa e enriquece dados das medições"""
        
        if df.empty:
            return df
        
        print(f"\n  Processando {len(df)} medições...")
        
        # Converter datas
        for col in ['measurementDate', 'dueDate']:
            if col in df.columns:
                df[col] = pd.to_datetime(df[col], errors='coerce')
        
        # Converter valores numéricos
        for col in ['totalLaborValue', 'totalMaterialValue', 'netValue', 'valueToRelease']:
            if col in df.columns:
                df[col] = pd.to_numeric(df[col], errors='coerce').fillna(0)
        
        # Traduzir status de aprovação
        status_map = {
            'PENDING': 'Pendente',
            'APPROVED': 'Aprovado',
            'REPROVED': 'Reprovado'
        }
        df['statusApprovalDesc'] = df['statusApproval'].map(status_map).fillna(df['statusApproval'])
        
        # Calcular idade da medição (dias desde medição até hoje)
        hoje = pd.Timestamp(datetime.now().date())
        df['diasDesdeMedicao'] = (hoje - df['measurementDate']).dt.days
        
        # Calcular dias até vencimento
        df['diasAteVencimento'] = (df['dueDate'] - hoje).dt.days
        
        # Status de vencimento
        df['statusVencimento'] = 'Indeterminado'
        df.loc[df['diasAteVencimento'] < 0, 'statusVencimento'] = 'Vencido'
        df.loc[df['diasAteVencimento'] == 0, 'statusVencimento'] = 'Vence Hoje'
        df.loc[(df['diasAteVencimento'] > 0) & (df['diasAteVencimento'] <= 7), 'statusVencimento'] = 'Vence em até 7 dias'
        df.loc[(df['diasAteVencimento'] > 7) & (df['diasAteVencimento'] <= 30), 'statusVencimento'] = 'Vence em até 30 dias'
        df.loc[df['diasAteVencimento'] > 30, 'statusVencimento'] = 'Vence em mais de 30 dias'
        
        # Percentual de liberação
        df['percLiberado'] = 0.0
        mask_valido = df['netValue'] > 0
        df.loc[mask_valido, 'percLiberado'] = (
            (df.loc[mask_valido, 'valueToRelease'] / df.loc[mask_valido, 'netValue']) * 100
        )
        
        # Status geral da medição
        df['statusGeral'] = 'Em Andamento'
        df.loc[df['finalized'] == True, 'statusGeral'] = 'Finalizada'
        df.loc[df['released'] == True, 'statusGeral'] = 'Liberada'
        df.loc[(df['finalized'] == True) & (df['released'] == True), 'statusGeral'] = 'Finalizada e Liberada'
        
        print(f"  ✓ Processamento concluído")
        
        return df
    
    def criar_resumo(self, df: pd.DataFrame) -> dict:
        """Cria resumo estatístico das medições"""
        
        resumo = {
            'total_medicoes': len(df),
            'obras_com_medicoes': df['buildingId'].nunique() if 'buildingId' in df.columns else 0,
            'contratos_medidos': df['documentId'].nunique() if 'documentId' in df.columns else 0,
            'valor_total_mao_obra': df['totalLaborValue'].sum(),
            'valor_total_material': df['totalMaterialValue'].sum(),
            'valor_liquido_total': df['netValue'].sum(),
            'valor_total_liberado': df['valueToRelease'].sum(),
            'perc_medio_liberado': df['percLiberado'].mean(),
            'medicoes_finalizadas': len(df[df['finalized'] == True]),
            'medicoes_liberadas': len(df[df['released'] == True]),
            'medicoes_autorizadas': len(df[df['authorized'] == True]),
            'medicoes_consistentes': len(df[df['consistent'] == True]),
        }
        
        # Distribuição por status de vencimento
        if 'statusVencimento' in df.columns:
            dist_vencimento = df.groupby('statusVencimento').agg({
                'documentId': 'count',
                'netValue': 'sum'
            }).sort_values('netValue', ascending=False)
            resumo['distribuicao_vencimento'] = dist_vencimento.to_dict('index')
        
        # Top obras com mais medições
        if 'buildingName' in df.columns:
            top_obras = df.groupby('buildingName').agg({
                'measurementNumber': 'count',
                'netValue': 'sum',
                'valueToRelease': 'sum'
            }).sort_values('netValue', ascending=False).head(10)
            top_obras = top_obras.rename(columns={'measurementNumber': 'qtd_medicoes'})
            resumo['top_obras'] = top_obras.to_dict('index')
        
        # Top contratos
        if 'contractNumber' in df.columns:
            top_contratos = df.groupby('contractNumber').agg({
                'measurementNumber': 'count',
                'netValue': 'sum',
                'valueToRelease': 'sum'
            }).sort_values('netValue', ascending=False).head(10)
            top_contratos = top_contratos.rename(columns={'measurementNumber': 'qtd_medicoes'})
            resumo['top_contratos'] = top_contratos.to_dict('index')
        
        return resumo
    
    def salvar_resultados(self, df: pd.DataFrame, resumo: dict) -> str:
        """Salva resultados em Excel formatado"""
        from openpyxl import load_workbook
        from openpyxl.worksheet.table import Table, TableStyleInfo
        from openpyxl.utils import get_column_letter
        from openpyxl.styles import Font, PatternFill
        
        timestamp = datetime.now().strftime('%Y%m%d_%H%M%S')
        arquivo = f'Medicoes_Contratos_Sienge_{timestamp}.xlsx'
        
        # Selecionar colunas para relatório
        colunas_relatorio = [
            'buildingName',
            'documentId',
            'contractNumber',
            'measurementNumber',
            'responsibleName',
            'statusApprovalDesc',
            'authorized',
            'consistent',
            'released',
            'finalized',
            'statusGeral',
            'measurementDate',
            'dueDate',
            'diasDesdeMedicao',
            'diasAteVencimento',
            'statusVencimento',
            'totalLaborValue',
            'totalMaterialValue',
            'netValue',
            'valueToRelease',
            'percLiberado',
            'notes'
        ]
        
        df_relatorio = df[[col for col in colunas_relatorio if col in df.columns]].copy()
        
        # Renomear colunas
        df_relatorio = df_relatorio.rename(columns={
            'buildingName': 'Obra',
            'documentId': 'ID Contrato',
            'contractNumber': 'Nº Contrato',
            'measurementNumber': 'Nº Medição',
            'responsibleName': 'Responsável',
            'statusApprovalDesc': 'Status Aprovação',
            'authorized': 'Autorizado',
            'consistent': 'Consistente',
            'released': 'Liberado',
            'finalized': 'Finalizado',
            'statusGeral': 'Status Geral',
            'measurementDate': 'Data Medição',
            'dueDate': 'Data Vencimento',
            'diasDesdeMedicao': 'Dias desde Medição',
            'diasAteVencimento': 'Dias até Vencimento',
            'statusVencimento': 'Status Vencimento',
            'totalLaborValue': 'Valor Mão de Obra',
            'totalMaterialValue': 'Valor Material',
            'netValue': 'Valor Líquido',
            'valueToRelease': 'Valor a Liberar',
            'percLiberado': '% Liberado',
            'notes': 'Observações'
        })
        
        # Criar Excel com múltiplas abas
        with pd.ExcelWriter(arquivo, engine='openpyxl') as writer:
            # ABA 1: Medições
            df_relatorio.to_excel(writer, sheet_name='Medições', index=False)
            
            # ABA 2: Resumo
            resumo_df = pd.DataFrame([
                ['RESUMO GERAL', ''],
                ['Total de Medições', resumo['total_medicoes']],
                ['Obras com Medições', resumo['obras_com_medicoes']],
                ['Contratos Medidos', resumo['contratos_medidos']],
                ['Valor Total Mão de Obra', f"R$ {resumo['valor_total_mao_obra']:,.2f}"],
                ['Valor Total Material', f"R$ {resumo['valor_total_material']:,.2f}"],
                ['Valor Líquido Total', f"R$ {resumo['valor_liquido_total']:,.2f}"],
                ['Valor Total a Liberar', f"R$ {resumo['valor_total_liberado']:,.2f}"],
                ['% Médio Liberado', f"{resumo['perc_medio_liberado']:.1f}%"],
                ['', ''],
                ['STATUS DAS MEDIÇÕES', ''],
                ['Medições Finalizadas', resumo['medicoes_finalizadas']],
                ['Medições Liberadas', resumo['medicoes_liberadas']],
                ['Medições Autorizadas', resumo['medicoes_autorizadas']],
                ['Medições Consistentes', resumo['medicoes_consistentes']],
            ])
            resumo_df.to_excel(writer, sheet_name='Resumo', index=False, header=False)
            
            # ABA 3: Top Obras
            if 'top_obras' in resumo and resumo['top_obras']:
                top_obras_df = pd.DataFrame.from_dict(resumo['top_obras'], orient='index')
                top_obras_df = top_obras_df.rename(columns={
                    'qtd_medicoes': 'Qtd Medições',
                    'netValue': 'Valor Líquido',
                    'valueToRelease': 'Valor a Liberar'
                })
                top_obras_df.index.name = 'Obra'
                top_obras_df.to_excel(writer, sheet_name='Top Obras')
            
            # ABA 4: Distribuição Vencimento
            if 'distribuicao_vencimento' in resumo and resumo['distribuicao_vencimento']:
                dist_venc_df = pd.DataFrame.from_dict(resumo['distribuicao_vencimento'], orient='index')
                dist_venc_df = dist_venc_df.rename(columns={
                    'documentId': 'Quantidade',
                    'netValue': 'Valor Total'
                })
                dist_venc_df.index.name = 'Status Vencimento'
                dist_venc_df.to_excel(writer, sheet_name='Distribuição Vencimento')
        
        # Aplicar formatação
        wb = load_workbook(arquivo)
        
        # Formatar aba "Medições"
        ws_medicoes = wb['Medições']
        
        if ws_medicoes.max_row > 1:
            ultima_coluna = get_column_letter(ws_medicoes.max_column)
            ref = f"A1:{ultima_coluna}{ws_medicoes.max_row}"
            
            tab = Table(displayName="TabelaMedicoes", ref=ref)
            style = TableStyleInfo(
                name="TableStyleMedium9",
                showFirstColumn=False,
                showLastColumn=False,
                showRowStripes=True,
                showColumnStripes=False
            )
            tab.tableStyleInfo = style
            ws_medicoes.add_table(tab)
            
            # Ajustar larguras
            for column in ws_medicoes.columns:
                max_length = 0
                column_letter = get_column_letter(column[0].column)
                for cell in column:
                    try:
                        if cell.value:
                            max_length = max(max_length, len(str(cell.value)))
                    except:
                        pass
                adjusted_width = min(max_length + 2, 60)
                ws_medicoes.column_dimensions[column_letter].width = adjusted_width
            
            # Formatar colunas de valores como moeda
            for row in range(2, ws_medicoes.max_row + 1):
                for col_letter in ['Q', 'R', 'S', 'T']:  # Colunas de valores
                    cell = ws_medicoes[f'{col_letter}{row}']
                    if cell.value is not None and isinstance(cell.value, (int, float)):
                        cell.number_format = 'R$ #,##0.00'
                
                # Formatar percentual
                cell_perc = ws_medicoes[f'U{row}']
                if cell_perc.value is not None and isinstance(cell_perc.value, (int, float)):
                    cell_perc.number_format = '0.00"%"'
            
            ws_medicoes.freeze_panes = 'A2'
        
        # Formatar aba "Resumo"
        ws_resumo = wb['Resumo']
        ws_resumo['A1'].font = Font(bold=True, size=14)
        ws_resumo['A1'].fill = PatternFill(start_color="4472C4", end_color="4472C4", fill_type="solid")
        ws_resumo['A1'].font = Font(bold=True, size=14, color="FFFFFF")
        
        ws_resumo['A11'].font = Font(bold=True, size=12)
        ws_resumo['A11'].fill = PatternFill(start_color="4472C4", end_color="4472C4", fill_type="solid")
        ws_resumo['A11'].font = Font(bold=True, size=12, color="FFFFFF")
        
        for row in [2, 3, 4, 5, 6, 7, 8, 9, 12, 13, 14, 15]:
            ws_resumo[f'A{row}'].font = Font(bold=True)
        
        ws_resumo.column_dimensions['A'].width = 40
        ws_resumo.column_dimensions['B'].width = 25
        
        wb.save(arquivo)
        wb.close()
        
        return arquivo


