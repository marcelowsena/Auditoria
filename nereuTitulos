"""
SIENGE - ANÁLISE DE PARCELAS FUTURAS (CONTAS A PAGAR)
Extrai parcelas a vencer e analisa fluxo de caixa futuro
"""

import base64
import json
import time
from datetime import datetime, date
from pathlib import Path
from typing import Optional, Tuple

import pandas as pd
import numpy as np
import requests


DEFAULT_CREDENTIALS_FILE = Path(__file__).with_name('sienge_credentials.json')


def carregar_credenciais(credentials_path: Optional[str] = None) -> Tuple[Optional[str], Optional[str]]:
    """Carrega credenciais do arquivo JSON"""
    path = Path(credentials_path) if credentials_path else DEFAULT_CREDENTIALS_FILE
    if path.exists():
        try:
            data = json.loads(path.read_text(encoding='utf-8'))
            return data.get('username'), data.get('password')
        except json.JSONDecodeError as exc:
            print(f'Erro ao ler credenciais: {exc}')
            return None, None
    return None, None


class SiengeParcelasFuturas:
    """Extrator de parcelas futuras de contas a pagar"""
    
    def __init__(self, username: str, password: str):
        self.username = username
        self.password = password
        self.base_url = 'https://api.sienge.com.br/trust/public/api'
        
        credentials = f"{username}:{password}"
        encoded = base64.b64encode(credentials.encode('utf-8')).decode('ascii')
        
        self.headers = {
            'Authorization': f'Basic {encoded}',
            'Content-Type': 'application/json',
            'Accept': 'application/json',
        }
    
    def _fazer_requisicao(self, url: str, max_tentativas: int = 3) -> dict:
        """Faz requisição HTTP com retry logic"""
        for tentativa in range(max_tentativas):
            try:
                response = requests.get(url, headers=self.headers, timeout=60)
                if response.status_code == 200:
                    return response.json()
                elif response.status_code == 429:
                    print("    ⚠ Rate limit - aguardando 60s...")
                    time.sleep(60)
                else:
                    if tentativa < max_tentativas - 1:
                        time.sleep(5)
            except requests.exceptions.RequestException as e:
                print(f"    ⚠ Erro na requisição: {str(e)[:50]}")
                if tentativa < max_tentativas - 1:
                    time.sleep(5)
        return {}
    
    def extrair_contas_pagar(self, data_inicio: str = "2024-01-01", 
                            data_fim: str = "2025-12-31") -> pd.DataFrame:
        """
        Extrai contas a pagar do Sienge
        
        Parâmetros do Power Query M:
        - startDate / endDate: período de análise
        - selectionType=I: tipo de seleção
        - correctionIndexerId=0: sem correção
        - withAuthorizations=false: sem autorizações
        - withBankMovements=true: incluir movimentações bancárias
        """
        
        url = (
            f"{self.base_url}/bulk-data/v1/outcome?"
            f"startDate={data_inicio}&"
            f"endDate={data_fim}&"
            f"selectionType=I&"
            f"correctionIndexerId=0&"
            f"correctionDate=2060-12-31&"
            f"withAuthorizations=false&"
            f"withBankMovements=true"
        )
        
        print(f"  Extraindo contas a pagar ({data_inicio} a {data_fim})...")
        
        dados = self._fazer_requisicao(url)
        
        if not dados or 'data' not in dados:
            return pd.DataFrame()
        
        # Converter para DataFrame
        df = pd.DataFrame(dados['data'])
        
        if df.empty:
            return df
        
        print(f"  ✓ {len(df)} registros extraídos")
        
        return df
    
    def processar_dados(self, df: pd.DataFrame, group_company_id: int = 1) -> pd.DataFrame:
        """
        Processa dados seguindo a lógica do Power Query M
        """
        
        if df.empty:
            return df
        
        print("\n  Processando dados...")
        
        # 1. EXPANDIR COLUNAS PRINCIPAIS
        colunas_base = [
            'companyId', 'companyName', 'businessAreaId', 'businessAreaName',
            'projectId', 'projectName', 'groupCompanyId', 'groupCompanyName',
            'holdingId', 'holdingName', 'subsidiaryId', 'subsidiaryName',
            'businessTypeId', 'businessTypeName', 'creditorId', 'creditorName',
            'billId', 'installmentId', 'documentIdentificationId', 
            'documentIdentificationName', 'documentNumber', 'forecastDocument',
            'consistencyStatus', 'originId', 'originalAmount', 'discountAmount',
            'taxAmount', 'indexerId', 'indexerName', 'dueDate', 'issueDate',
            'installmentBaseDate', 'balanceAmount', 'correctedBalanceAmount',
            'authorizationStatus', 'billDate', 'registeredUserId', 'registeredBy',
            'registeredDate', 'paymentsCategories', 'departamentsCosts', 
            'buildingsCosts', 'payments', 'authorizations'
        ]
        
        # Garantir que todas as colunas existem
        for col in colunas_base:
            if col not in df.columns:
                df[col] = None
        
        # 2. EXTRAIR DATA DE REGISTRO (apenas a data, sem hora)
        df['Data de Registro'] = pd.to_datetime(
            df['registeredDate'].str.split('T').str[0], 
            errors='coerce'
        )
        
        # 3. CONVERTER DATAS
        df['issueDate'] = pd.to_datetime(df['issueDate'], errors='coerce')
        df['dueDate'] = pd.to_datetime(df['dueDate'], errors='coerce')
        
        # 4. CALCULAR DURAÇÃO (dias entre vencimento e registro)
        df['Duração'] = (df['dueDate'] - df['Data de Registro']).dt.days
        
        # 5. CLASSIFICAR PAGAMENTO
        def classificar_pagamento(duracao):
            if pd.isna(duracao):
                return "Sem data"
            elif duracao < 0:
                return "Vencido"
            elif duracao == 0:
                return "No dia"
            elif duracao == 1:
                return "1 dia antes"
            elif 2 <= duracao <= 7:
                return "Entre 2 a 7 dias"
            else:
                return "Mais que 7 dias"
        
        df['Classificação'] = df['Duração'].apply(classificar_pagamento)
        
        # 6. CONVERTER VALORES NUMÉRICOS
        df['originalAmount'] = pd.to_numeric(df['originalAmount'], errors='coerce')
        df['taxAmount'] = pd.to_numeric(df['taxAmount'], errors='coerce')
        df['balanceAmount'] = pd.to_numeric(df['balanceAmount'], errors='coerce')
        
        # 7. ADICIONAR ÍNDICE
        df['Índice'] = range(1, len(df) + 1)
        
        # 8. EXPANDIR buildingsCosts (obras)
        df_expandido = []
        for idx, row in df.iterrows():
            buildings = row.get('buildingsCosts', [])
            if buildings and isinstance(buildings, list) and len(buildings) > 0:
                for building in buildings:
                    nova_linha = row.copy()
                    nova_linha['buildingName'] = building.get('buildingName', '')
                    nova_linha['buildingUnitName'] = building.get('buildingUnitName', '')
                    df_expandido.append(nova_linha)
            else:
                nova_linha = row.copy()
                nova_linha['buildingName'] = ''
                nova_linha['buildingUnitName'] = ''
                df_expandido.append(nova_linha)
        
        df = pd.DataFrame(df_expandido)
        
        # 9. REMOVER DUPLICATAS POR ÍNDICE
        df = df.drop_duplicates(subset=['Índice'], keep='first')
        
        # 10. FILTRAR POR GRUPO EMPRESARIAL
        df = df[df['groupCompanyId'] == group_company_id].copy()
        
        # 11. EXPANDIR departamentsCosts
        df_expandido = []
        for idx, row in df.iterrows():
            departments = row.get('departamentsCosts', [])
            if departments and isinstance(departments, list) and len(departments) > 0:
                for dept in departments:
                    nova_linha = row.copy()
                    nova_linha['departmentId'] = dept.get('departmentId', '')
                    nova_linha['departmentName'] = dept.get('departmentName', '')
                    df_expandido.append(nova_linha)
            else:
                nova_linha = row.copy()
                nova_linha['departmentId'] = ''
                nova_linha['departmentName'] = ''
                df_expandido.append(nova_linha)
        
        df = pd.DataFrame(df_expandido)
        
        # 12. EXPANDIR payments (pagamentos realizados)
        df_expandido = []
        for idx, row in df.iterrows():
            payments = row.get('payments', [])
            if payments and isinstance(payments, list) and len(payments) > 0:
                for payment in payments:
                    nova_linha = row.copy()
                    nova_linha['payment_interestAmount'] = payment.get('interestAmount', 0)
                    nova_linha['payment_fineAmount'] = payment.get('fineAmount', 0)
                    nova_linha['payment_paymentDate'] = payment.get('paymentDate', '')
                    df_expandido.append(nova_linha)
            else:
                nova_linha = row.copy()
                nova_linha['payment_interestAmount'] = 0
                nova_linha['payment_fineAmount'] = 0
                nova_linha['payment_paymentDate'] = ''
                df_expandido.append(nova_linha)
        
        df = pd.DataFrame(df_expandido)
        
        # 13. CONVERTER COLUNAS DE PAGAMENTO
        df['payment_paymentDate'] = pd.to_datetime(df['payment_paymentDate'], errors='coerce')
        df['payment_fineAmount'] = pd.to_numeric(df['payment_fineAmount'], errors='coerce').fillna(0)
        df['payment_interestAmount'] = pd.to_numeric(df['payment_interestAmount'], errors='coerce').fillna(0)
        
        # 14. ORDENAR POR DATA DE VENCIMENTO (DECRESCENTE)
        df = df.sort_values('dueDate', ascending=False)
        
        print(f"  ✓ {len(df)} registros após processamento")
        
        return df
    
    def filtrar_parcelas_futuras(self, df: pd.DataFrame) -> pd.DataFrame:
        """
        Filtra apenas parcelas futuras (não pagas)
        """
        
        hoje = pd.Timestamp(date.today())
        
        # Filtrar parcelas onde:
        # 1. Não há data de pagamento OU
        # 2. Data de vencimento é futura
        df_futuras = df[
            (df['payment_paymentDate'].isna()) | 
            (df['dueDate'] >= hoje)
        ].copy()
        
        # Remover parcelas já pagas (balanceAmount = 0 ou negativo)
        df_futuras = df_futuras[df_futuras['balanceAmount'] > 0].copy()
        
        return df_futuras
    
    def criar_resumo_futuro(self, df_futuras: pd.DataFrame) -> dict:
        """
        Cria resumo das parcelas futuras
        """
        
        hoje = date.today()
        
        resumo = {
            'total_parcelas': len(df_futuras),
            'valor_total': df_futuras['balanceAmount'].sum(),
            'valor_total_original': df_futuras['originalAmount'].sum(),
            'parcelas_vencidas': len(df_futuras[df_futuras['dueDate'] < pd.Timestamp(hoje)]),
            'parcelas_mes_atual': len(df_futuras[
                (df_futuras['dueDate'].dt.year == hoje.year) &
                (df_futuras['dueDate'].dt.month == hoje.month)
            ]),
            'parcelas_30_dias': len(df_futuras[
                (df_futuras['dueDate'] >= pd.Timestamp(hoje)) &
                (df_futuras['dueDate'] <= pd.Timestamp(hoje) + pd.Timedelta(days=30))
            ]),
            'valor_30_dias': df_futuras[
                (df_futuras['dueDate'] >= pd.Timestamp(hoje)) &
                (df_futuras['dueDate'] <= pd.Timestamp(hoje) + pd.Timedelta(days=30))
            ]['balanceAmount'].sum(),
        }
        
        # Resumo por obra
        resumo_obras = df_futuras.groupby('buildingName').agg({
            'balanceAmount': 'sum',
            'installmentId': 'count'
        }).sort_values('balanceAmount', ascending=False)
        
        resumo['top_obras'] = resumo_obras.head(10).to_dict('index')
        
        # Resumo por fornecedor
        resumo_fornecedores = df_futuras.groupby('creditorName').agg({
            'balanceAmount': 'sum',
            'installmentId': 'count'
        }).sort_values('balanceAmount', ascending=False)
        
        resumo['top_fornecedores'] = resumo_fornecedores.head(10).to_dict('index')
        
        return resumo
    
    def salvar_resultados(self, df_futuras: pd.DataFrame, resumo: dict) -> str:
        """Salva resultados em Excel formatado"""
        from openpyxl import load_workbook
        from openpyxl.worksheet.table import Table, TableStyleInfo
        from openpyxl.utils import get_column_letter
        from openpyxl.styles import Font, PatternFill, Alignment, numbers
        
        timestamp = datetime.now().strftime('%Y%m%d_%H%M%S')
        arquivo = f'Parcelas_Futuras_Sienge_{timestamp}.xlsx'
        
        # Selecionar colunas relevantes para o relatório
        colunas_relatorio = [
            'Índice',
            'groupCompanyName',
            'projectName',
            'buildingName',
            'creditorName',
            'documentNumber',
            'installmentId',
            'dueDate',
            'issueDate',
            'Data de Registro',
            'originalAmount',
            'balanceAmount',
            'taxAmount',
            'Classificação',
            'Duração',
            'payment_paymentDate',
            'payment_fineAmount',
            'payment_interestAmount'
        ]
        
        df_relatorio = df_futuras[
            [col for col in colunas_relatorio if col in df_futuras.columns]
        ].copy()
        
        # Renomear colunas para português
        df_relatorio = df_relatorio.rename(columns={
            'groupCompanyName': 'Empresa',
            'projectName': 'Projeto',
            'buildingName': 'Obra',
            'creditorName': 'Fornecedor',
            'documentNumber': 'Nº Documento',
            'installmentId': 'ID Parcela',
            'dueDate': 'Data Vencimento',
            'issueDate': 'Data Emissão',
            'originalAmount': 'Valor Original',
            'balanceAmount': 'Saldo Devedor',
            'taxAmount': 'Valor Impostos',
            'payment_paymentDate': 'Data Pagamento',
            'payment_fineAmount': 'Multa',
            'payment_interestAmount': 'Juros'
        })
        
        # Criar escritor Excel
        with pd.ExcelWriter(arquivo, engine='openpyxl') as writer:
            # ABA 1: Parcelas Futuras
            df_relatorio.to_excel(writer, sheet_name='Parcelas Futuras', index=False)
            
            # ABA 2: Resumo
            resumo_df = pd.DataFrame([
                ['RESUMO GERAL', ''],
                ['Total de Parcelas Futuras', resumo['total_parcelas']],
                ['Valor Total a Pagar', f"R$ {resumo['valor_total']:,.2f}"],
                ['Valor Original', f"R$ {resumo['valor_total_original']:,.2f}"],
                ['Parcelas Vencidas', resumo['parcelas_vencidas']],
                ['Parcelas no Mês Atual', resumo['parcelas_mes_atual']],
                ['Parcelas nos Próximos 30 dias', resumo['parcelas_30_dias']],
                ['Valor nos Próximos 30 dias', f"R$ {resumo['valor_30_dias']:,.2f}"],
            ])
            resumo_df.to_excel(writer, sheet_name='Resumo', index=False, header=False)
        
        # Aplicar formatação
        wb = load_workbook(arquivo)
        
        # Formatar aba "Parcelas Futuras"
        ws_parcelas = wb['Parcelas Futuras']
        
        if ws_parcelas.max_row > 1:
            ultima_coluna = get_column_letter(ws_parcelas.max_column)
            ref = f"A1:{ultima_coluna}{ws_parcelas.max_row}"
            
            tab = Table(displayName="TabelaParcelasFuturas", ref=ref)
            style = TableStyleInfo(
                name="TableStyleMedium9",
                showFirstColumn=False,
                showLastColumn=False,
                showRowStripes=True,
                showColumnStripes=False
            )
            tab.tableStyleInfo = style
            ws_parcelas.add_table(tab)
            
            # Ajustar larguras
            for column in ws_parcelas.columns:
                max_length = 0
                column_letter = get_column_letter(column[0].column)
                for cell in column:
                    try:
                        if cell.value:
                            max_length = max(max_length, len(str(cell.value)))
                    except:
                        pass
                adjusted_width = min(max_length + 2, 50)
                ws_parcelas.column_dimensions[column_letter].width = adjusted_width
            
            # Formatar colunas de valores como moeda
            for row in range(2, ws_parcelas.max_row + 1):
                for col in ['K', 'L', 'M', 'Q', 'R']:  # Colunas de valores
                    cell = ws_parcelas[f'{col}{row}']
                    if cell.value is not None:
                        cell.number_format = 'R$ #,##0.00'
            
            ws_parcelas.freeze_panes = 'A2'
        
        # Formatar aba "Resumo"
        ws_resumo = wb['Resumo']
        ws_resumo['A1'].font = Font(bold=True, size=14)
        ws_resumo['A1'].fill = PatternFill(start_color="4472C4", end_color="4472C4", fill_type="solid")
        ws_resumo['A1'].font = Font(bold=True, size=14, color="FFFFFF")
        
        for row in range(2, 9):
            ws_resumo[f'A{row}'].font = Font(bold=True)
        
        ws_resumo.column_dimensions['A'].width = 40
        ws_resumo.column_dimensions['B'].width = 25
        
        wb.save(arquivo)
        wb.close()
        
        return arquivo


