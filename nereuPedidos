"""
SIENGE - CONSULTA PEDIDOS SEM ORÇAMENTO - NEREU RAMOS SPE
Script simplificado para identificar pedidos sem cobertura orçamentária
"""

import base64
import json
import time
from datetime import datetime
from pathlib import Path
from typing import Optional, Tuple, List

import pandas as pd
import requests


DEFAULT_CREDENTIALS_FILE = Path(__file__).with_name('sienge_credentials.json')


def carregar_credenciais(credentials_path: Optional[str] = None) -> Tuple[Optional[str], Optional[str]]:
    """Carrega credenciais do arquivo JSON"""
    path = Path(credentials_path) if credentials_path else DEFAULT_CREDENTIALS_FILE
    if path.exists():
        try:
            data = json.loads(path.read_text(encoding='utf-8'))
            return data.get('username'), data.get('password')
        except json.JSONDecodeError as exc:
            print(f'Erro ao ler credenciais: {exc}')
            return None, None
    return None, None


class SiengeConsultorPedidos:
    """Consultor simplificado para pedidos sem orçamento"""
    
    # Obras específicas do projeto Nereu Ramos SPE
    OBRAS_ALVO = [
        "Nereu Ramos SPE - Administrativo",
        "Nereu Ramos SPE - Marketing",
        "Nereu Ramos SPE - Comercial",
        "Nereu Ramos SPE - Empréstimos e Financiamentos",
        "Nereu Ramos SPE - Permutas",
        "Nereu Ramos SPE - Obra"
    ]
    
    def __init__(self, username: str, password: str):
        self.username = username
        self.password = password
        self.base_url = 'https://api.sienge.com.br/trust/public/api'
        
        credentials = f"{username}:{password}"
        encoded = base64.b64encode(credentials.encode('utf-8')).decode('ascii')
        
        self.headers = {
            'Authorization': f'Basic {encoded}',
            'Content-Type': 'application/json',
            'Accept': 'application/json',
        }
    
    def _fazer_requisicao(self, url: str, params: dict = None, max_tentativas: int = 3) -> dict:
        """Faz requisição HTTP com retry logic"""
        for tentativa in range(max_tentativas):
            try:
                response = requests.get(url, headers=self.headers, params=params, timeout=30)
                if response.status_code == 200:
                    return response.json()
                elif response.status_code == 429:
                    time.sleep(60)
                else:
                    if tentativa < max_tentativas - 1:
                        time.sleep(5)
            except requests.exceptions.RequestException:
                if tentativa < max_tentativas - 1:
                    time.sleep(5)
        return {}
    
    def _paginar_resultados(self, url: str, params: dict) -> List[dict]:
        """Paginação robusta"""
        todos_resultados = []
        offset = 0
        offsets_visitados = set()
        tentativas_sem_dados = 0
        
        while tentativas_sem_dados < 3:
            if offset in offsets_visitados:
                break
            offsets_visitados.add(offset)
            
            params['offset'] = offset
            dados = self._fazer_requisicao(url, params)
            
            if not dados:
                tentativas_sem_dados += 1
                offset += 200
                continue
            
            results = dados.get('results', [])
            if not results:
                break
            
            todos_resultados.extend(results)
            tentativas_sem_dados = 0
            
            if len(results) < params.get('limit', 200):
                break
            
            next_offset = dados.get('nextOffset')
            if next_offset is not None and next_offset != offset:
                offset = next_offset
            else:
                offset += len(results)
            
            time.sleep(0.3)
        
        return todos_resultados
    
    def buscar_obras_nereu_ramos(self) -> pd.DataFrame:
        """Busca apenas as obras do projeto Nereu Ramos SPE"""
        url = f"{self.base_url}/v1/enterprises"
        params = {'limit': 200, 'offset': 0}
        
        todos = self._paginar_resultados(url, params)
        if not todos:
            return pd.DataFrame()
        
        df = pd.DataFrame(todos)
        df = df.rename(columns={'id': 'ID', 'name': 'Obra'})
        
        # Filtrar apenas obras Nereu Ramos SPE específicas
        df = df[df['Obra'].isin(self.OBRAS_ALVO)]
        
        return df.sort_values('Obra').reset_index(drop=True)
    
    def extrair_orcamento(self, building_id: int) -> pd.DataFrame:
        """Extrai orçamento de uma obra"""
        url = f"{self.base_url}/bulk-data/v1/building/resources"
        params = {
            'buildingId': building_id,
            'startDate': '2024-01-01',
            'endDate': '2025-12-31',
            'includeDisbursement': False,
            'bdi': '0.00',
            'laborBurden': '0.00'
        }
        
        data = self._fazer_requisicao(url, params)
        if not data or not data.get('data'):
            return pd.DataFrame()
        
        recursos = [{
            'id_insumo': str(item.get('id', '')),
            'codigo_insumo': item.get('resourceCode'),
            'insumo': item.get('description'),
            'categoria': item.get('category', ''),
            'preco_unitario_orcado': item.get('unitPrice', 0),
            'unidade_medida': item.get('unitOfMeasure'),
        } for item in data['data']]
        
        return pd.DataFrame(recursos)
    
    def extrair_pedidos(self, building_id: int) -> pd.DataFrame:
        """Extrai pedidos de uma obra"""
        url = f"{self.base_url}/v1/purchase-orders"
        params = {
            'buildingId': building_id,
            'startDate': '2024-01-01',
            'endDate': '2025-12-31',
            'limit': 200,
            'offset': 0
        }
        
        todos = self._paginar_resultados(url, params)
        if not todos:
            return pd.DataFrame()
        
        pedidos_unicos = {p['id']: p for p in todos}.values()
        df = pd.DataFrame(pedidos_unicos)
        
        if 'date' in df.columns:
            df['date'] = pd.to_datetime(df['date'], errors='coerce')
        
        return df
    
    def extrair_itens_pedidos(self, pedidos_ids: list) -> pd.DataFrame:
        """Extrai itens de múltiplos pedidos"""
        todos_itens = []
        
        for pedido_id in pedidos_ids:
            url = f"{self.base_url}/v1/purchase-orders/{pedido_id}/items"
            params = {'limit': 200, 'offset': 0}
            
            itens = self._paginar_resultados(url, params)
            
            for item in itens:
                item['pedido_id'] = pedido_id
            
            todos_itens.extend(itens)
            time.sleep(0.3)
        
        if not todos_itens:
            return pd.DataFrame()
        
        return pd.DataFrame(todos_itens)
    
    def identificar_pedidos_sem_orcamento(self, df_orcamento: pd.DataFrame, df_itens: pd.DataFrame, 
                                          df_pedidos: pd.DataFrame) -> pd.DataFrame:
        """Identifica itens de pedidos que não possuem cobertura orçamentária"""
        
        if df_itens.empty:
            return pd.DataFrame()
        
        # Normalizar IDs de insumos
        df_itens['id_insumo'] = df_itens.get('resourceId', df_itens.get('resourceCode', '')).astype(str)
        
        # Criar conjunto de IDs orçados
        ids_orcados = set()
        if not df_orcamento.empty:
            ids_orcados = set(df_orcamento['id_insumo'].astype(str).unique())
        
        # Filtrar itens SEM orçamento
        df_sem_orcamento = df_itens[~df_itens['id_insumo'].isin(ids_orcados)].copy()
        
        if df_sem_orcamento.empty:
            return pd.DataFrame()
        
        # Enriquecer com dados do pedido
        if not df_pedidos.empty:
            pedidos_info = df_pedidos[['id', 'date', 'authorized', 'supplierId']].copy()
            pedidos_info['pedido_id'] = pedidos_info['id']
            df_sem_orcamento = df_sem_orcamento.merge(
                pedidos_info, on='pedido_id', how='left', suffixes=('', '_p')
            )
        
        # Preparar colunas finais
        df_resultado = pd.DataFrame({
            'obra': df_sem_orcamento['nome_obra'],
            'numero_pedido': df_sem_orcamento['pedido_id'].astype(str),
            'data_pedido': df_sem_orcamento.get('date', ''),
            'pedido_autorizado': df_sem_orcamento.get('authorized', False),
            'id_insumo': df_sem_orcamento['id_insumo'],
            'insumo': df_sem_orcamento.get('resourceDescription', ''),
            'quantidade': pd.to_numeric(df_sem_orcamento.get('quantity', 0), errors='coerce'),
            'preco_unitario': pd.to_numeric(df_sem_orcamento.get('unitPrice', 0), errors='coerce'),
            'unidade_medida': df_sem_orcamento.get('unitOfMeasure', ''),
            'valor_total_item': (
                pd.to_numeric(df_sem_orcamento.get('quantity', 0), errors='coerce') * 
                pd.to_numeric(df_sem_orcamento.get('unitPrice', 0), errors='coerce')
            ),
            'fornecedor_id': df_sem_orcamento.get('supplierId', ''),
        })
        
        # Remover duplicatas
        df_resultado = df_resultado.drop_duplicates(
            subset=['numero_pedido', 'id_insumo'],
            keep='first'
        )
        
        return df_resultado.sort_values(['obra', 'numero_pedido']).reset_index(drop=True)
    
    def salvar_resultado(self, df_resultado: pd.DataFrame) -> str:
        """Salva resultado em Excel formatado"""
        from openpyxl import load_workbook
        from openpyxl.worksheet.table import Table, TableStyleInfo
        from openpyxl.utils import get_column_letter
        
        timestamp = datetime.now().strftime('%Y%m%d_%H%M%S')
        arquivo = f'Pedidos_Sem_Orcamento_Nereu_Ramos_{timestamp}.xlsx'
        
        # Salvar Excel
        df_resultado.to_excel(arquivo, index=False, engine='openpyxl')
        
        # Aplicar formatação de tabela
        wb = load_workbook(arquivo)
        ws = wb.active
        
        max_row = ws.max_row
        max_col = ws.max_column
        
        if max_row > 1:
            ultima_coluna = get_column_letter(max_col)
            ref = f"A1:{ultima_coluna}{max_row}"
            
            tab = Table(displayName="TabelaPedidosSemOrcamento", ref=ref)
            style = TableStyleInfo(
                name="TableStyleMedium9",
                showFirstColumn=False,
                showLastColumn=False,
                showRowStripes=True,
                showColumnStripes=False
            )
            tab.tableStyleInfo = style
            ws.add_table(tab)
            
            # Ajustar largura das colunas
            for column in ws.columns:
                max_length = 0
                column_letter = get_column_letter(column[0].column)
                for cell in column:
                    try:
                        if cell.value:
                            max_length = max(max_length, len(str(cell.value)))
                    except:
                        pass
                adjusted_width = min(max_length + 2, 50)
                ws.column_dimensions[column_letter].width = adjusted_width
            
            ws.freeze_panes = 'A2'
        
        wb.save(arquivo)
        wb.close()
        
        return arquivo


if __name__ == "__main__":
    print("="*70)
    print("CONSULTA PEDIDOS SEM ORÇAMENTO - NEREU RAMOS SPE")
    print("="*70)
    
    username, password = carregar_credenciais()
    if not username or not password:
        print("\n⚠ ERRO: Configure sienge_credentials.json")
        exit(1)
    
    inicio = time.time()
    consultor = SiengeConsultorPedidos(username, password)
    
    print("\n[1/4] Buscando obras Nereu Ramos SPE...")
    df_obras = consultor.buscar_obras_nereu_ramos()
    
    if df_obras.empty:
        print("\n⚠ Nenhuma obra Nereu Ramos SPE encontrada")
        exit(1)
    
    print(f"✓ {len(df_obras)} obras encontradas:")
    for idx, obra in enumerate(df_obras['Obra'], 1):
        print(f"  {idx}. {obra}")
    
    print("\n[2/4] Extraindo orçamentos e pedidos...")
    todos_resultados = []
    
    for idx, row in df_obras.iterrows():
        obra_id = row['ID']
        obra_nome = row['Obra']
        
        print(f"  Processando: {obra_nome}")
        
        try:
            # Buscar orçamento
            df_orc = consultor.extrair_orcamento(obra_id)
            
            # Buscar pedidos
            df_ped = consultor.extrair_pedidos(obra_id)
            
            if df_ped.empty:
                print(f"    ⚠ Sem pedidos")
                continue
            
            # Buscar itens dos pedidos
            ids_pedidos = df_ped['id'].tolist()
            df_itens = consultor.extrair_itens_pedidos(ids_pedidos)
            
            if df_itens.empty:
                print(f"    ⚠ Sem itens")
                continue
            
            # Adicionar identificação da obra
            df_itens['nome_obra'] = obra_nome
            
            # Identificar itens sem orçamento
            print(f"  [3/4] Identificando pedidos sem orçamento...")
            df_sem_orc = consultor.identificar_pedidos_sem_orcamento(df_orc, df_itens, df_ped)
            
            if not df_sem_orc.empty:
                todos_resultados.append(df_sem_orc)
                print(f"    ✓ {len(df_sem_orc)} itens sem orçamento")
            else:
                print(f"    ✓ Todos os itens possuem orçamento")
                
        except Exception as e:
            print(f"    ⚠ Erro: {str(e)[:50]}")
            continue
    
    if not todos_resultados:
        print("\n✓ RESULTADO: Todos os pedidos possuem cobertura orçamentária!")
        exit(0)
    
    # Consolidar resultados
    df_final = pd.concat(todos_resultados, ignore_index=True)
    
    print("\n[4/4] Salvando resultado...")
    arquivo = consultor.salvar_resultado(df_final)
    
    tempo_total = time.time() - inicio
    
    # Estatísticas
    valor_total = df_final['valor_total_item'].sum()
    pedidos_unicos = df_final['numero_pedido'].nunique()
    itens_total = len(df_final)
    
    print(f"\n{'='*70}")
    print(f"CONSULTA CONCLUÍDA")
    print(f"{'='*70}")
    print(f"Tempo: {tempo_total/60:.1f} min")
    print(f"Obras analisadas: {len(df_obras)}")
    print(f"Pedidos sem orçamento: {pedidos_unicos}")
    print(f"Itens sem orçamento: {itens_total}")
    print(f"Valor total sem cobertura: R$ {valor_total:,.2f}")
    print(f"\n📁 Arquivo gerado: {arquivo}")
    print(f"{'='*70}")
    
    # Resumo por obra
    print("\n📊 RESUMO POR OBRA:")
    resumo = df_final.groupby('obra').agg({
        'numero_pedido': 'nunique',
        'id_insumo': 'count',
        'valor_total_item': 'sum'
    }).rename(columns={
        'numero_pedido': 'Pedidos',
        'id_insumo': 'Itens',
        'valor_total_item': 'Valor Total'
    })
    
    for obra, stats in resumo.iterrows():
        print(f"\n  {obra}")
        print(f"    Pedidos: {int(stats['Pedidos'])}")
        print(f"    Itens: {int(stats['Itens'])}")
        print(f"    Valor: R$ {stats['Valor Total']:,.2f}")