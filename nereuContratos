"""
SIENGE - EXTRAÇÃO DE CONTRATOS DE FORNECIMENTO
Extrai contratos aprovados e autorizados com paginação automática
"""

import base64
import json
import time
from datetime import datetime
from pathlib import Path
from typing import Optional, Tuple, List

import pandas as pd
import requests


DEFAULT_CREDENTIALS_FILE = Path(__file__).with_name('sienge_credentials.json')


def carregar_credenciais(credentials_path: Optional[str] = None) -> Tuple[Optional[str], Optional[str]]:
    """Carrega credenciais do arquivo JSON"""
    path = Path(credentials_path) if credentials_path else DEFAULT_CREDENTIALS_FILE
    if path.exists():
        try:
            data = json.loads(path.read_text(encoding='utf-8'))
            return data.get('username'), data.get('password')
        except json.JSONDecodeError as exc:
            print(f'Erro ao ler credenciais: {exc}')
            return None, None
    return None, None


class SiengeContratosExtractor:
    """Extrator de contratos de fornecimento do Sienge"""
    
    def __init__(self, username: str, password: str):
        self.username = username
        self.password = password
        self.base_url = 'https://api.sienge.com.br/trust/public/api'
        
        credentials = f"{username}:{password}"
        encoded = base64.b64encode(credentials.encode('utf-8')).decode('ascii')
        
        self.headers = {
            'Authorization': f'Basic {encoded}',
            'Content-Type': 'application/json',
            'Accept': 'application/json',
        }
    
    def _fazer_requisicao(self, url: str, params: dict = None, max_tentativas: int = 3) -> dict:
        """Faz requisição HTTP com retry logic"""
        for tentativa in range(max_tentativas):
            try:
                response = requests.get(url, headers=self.headers, params=params, timeout=30)
                if response.status_code == 200:
                    return response.json()
                elif response.status_code == 429:
                    print("    ⚠ Rate limit - aguardando 60s...")
                    time.sleep(60)
                else:
                    print(f"    ⚠ Status code: {response.status_code}")
                    if tentativa < max_tentativas - 1:
                        time.sleep(5)
            except requests.exceptions.RequestException as e:
                print(f"    ⚠ Erro na requisição: {str(e)[:50]}")
                if tentativa < max_tentativas - 1:
                    time.sleep(5)
        return {}
    
    def extrair_contratos(
        self, 
        data_inicio: str = "2025-01-01",
        data_fim: str = "2025-12-31",
        status_aprovacao: str = "A",  # A=Aprovado
        autorizacao: str = "A",        # A=Autorizado
        consistencia: str = "S"        # S=Consistente
    ) -> pd.DataFrame:
        """
        Extrai contratos de fornecimento com paginação automática
        
        Parâmetros:
        - contractStartDate/contractEndDate: período do contrato
        - statusApproval: A (Aprovado), P (Pendente), R (Reprovado)
        - authorization: A (Autorizado), P (Pendente)
        - consistency: S (Consistente), N (Não consistente)
        """
        
        url = f"{self.base_url}/v1/supply-contracts/all"
        
        params = {
            'contractStartDate': data_inicio,
            'contractEndDate': data_fim,
            'statusApproval': status_aprovacao,
            'authorization': autorizacao,
            'consistency': consistencia,
            'limit': 200,
            'offset': 0
        }
        
        print(f"\n  Extraindo contratos ({data_inicio} a {data_fim})...")
        print(f"    Filtros: Aprovação={status_aprovacao}, Autorização={autorizacao}, Consistência={consistencia}")
        
        todos_contratos = []
        offset = 0
        offsets_visitados = set()
        tentativas_vazias = 0
        total_extraido = 0
        
        while tentativas_vazias < 3:
            # Evitar loop infinito
            if offset in offsets_visitados:
                print(f"    ⚠ Offset {offset} já visitado, encerrando paginação")
                break
            
            offsets_visitados.add(offset)
            params['offset'] = offset
            
            print(f"    Buscando registros (offset={offset})...", end=' ')
            
            dados = self._fazer_requisicao(url, params)
            
            if not dados:
                print("❌ Sem resposta")
                tentativas_vazias += 1
                offset += 200
                continue
            
            results = dados.get('results', [])
            
            if not results:
                print("❌ Sem resultados")
                tentativas_vazias += 1
                offset += 200
                continue
            
            # Sucesso
            qtd_atual = len(results)
            todos_contratos.extend(results)
            total_extraido += qtd_atual
            print(f"✓ {qtd_atual} contratos")
            
            tentativas_vazias = 0
            
            # Verificar se há mais páginas
            if qtd_atual < params['limit']:
                print(f"    ✓ Última página alcançada")
                break
            
            # Próximo offset
            next_offset = dados.get('nextOffset')
            if next_offset is not None and next_offset != offset:
                offset = next_offset
            else:
                offset += qtd_atual
            
            # Delay para não sobrecarregar API
            time.sleep(0.3)
        
        if not todos_contratos:
            print(f"\n  ⚠ Nenhum contrato encontrado")
            return pd.DataFrame()
        
        print(f"\n  ✓ Total extraído: {total_extraido} contratos")
        
        return pd.DataFrame(todos_contratos)
    
    def processar_contratos(self, df: pd.DataFrame) -> pd.DataFrame:
        """Processa e enriquece dados dos contratos"""
        
        if df.empty:
            return df
        
        print(f"\n  Processando {len(df)} contratos...")
        
        # Expandir buildings (obras vinculadas ao contrato)
        df_expandido = []
        
        for idx, row in df.iterrows():
            buildings = row.get('buildings', [])
            
            if buildings and isinstance(buildings, list) and len(buildings) > 0:
                # Um registro para cada obra vinculada
                for building in buildings:
                    nova_linha = row.copy()
                    nova_linha['buildingId'] = building.get('buildingId', '')
                    nova_linha['buildingName'] = building.get('name', '')
                    df_expandido.append(nova_linha)
            else:
                # Contrato sem obra vinculada
                nova_linha = row.copy()
                nova_linha['buildingId'] = ''
                nova_linha['buildingName'] = 'SEM OBRA'
                df_expandido.append(nova_linha)
        
        df = pd.DataFrame(df_expandido)
        
        # Converter datas
        for col in ['contractDate', 'startDate', 'endDate']:
            if col in df.columns:
                df[col] = pd.to_datetime(df[col], errors='coerce')
        
        # Converter valores numéricos
        for col in ['totalLaborValue', 'totalMaterialValue']:
            if col in df.columns:
                df[col] = pd.to_numeric(df[col], errors='coerce').fillna(0)
        
        # Calcular valor total do contrato
        df['totalValue'] = df['totalLaborValue'] + df['totalMaterialValue']
        
        # Traduzir status
        status_map = {
            'PENDING': 'Pendente',
            'APPROVED': 'Aprovado',
            'REPROVED': 'Reprovado'
        }
        df['statusApprovalDesc'] = df['statusApproval'].map(status_map).fillna(df['statusApproval'])
        
        # Traduzir tipo de contrato
        contract_type_map = {
            'CONTRACTOR': 'Empreiteiro',
            'SUPPLIER': 'Fornecedor',
            'SERVICE': 'Serviço'
        }
        df['contractTypeDesc'] = df['contractType'].map(contract_type_map).fillna(df['contractType'])
        
        # Traduzir tipo de registro
        registration_type_map = {
            'COMPLETE': 'Completo',
            'SIMPLIFIED': 'Simplificado'
        }
        df['registrationTypeDesc'] = df['registrationType'].map(registration_type_map).fillna(df['registrationType'])
        
        # Traduzir tipo de item
        item_type_map = {
            'RESOURCE': 'Insumo',
            'PACKAGE': 'Pacote',
            'SERVICE': 'Serviço'
        }
        df['itemTypeDesc'] = df['itemType'].map(item_type_map).fillna(df['itemType'])
        
        # Calcular duração do contrato (em dias)
        df['contratoduracaoDias'] = (df['endDate'] - df['startDate']).dt.days
        
        # Status de vigência
        hoje = pd.Timestamp(datetime.now().date())
        df['statusVigencia'] = 'Indeterminado'
        df.loc[df['endDate'] < hoje, 'statusVigencia'] = 'Vencido'
        df.loc[(df['startDate'] <= hoje) & (df['endDate'] >= hoje), 'statusVigencia'] = 'Vigente'
        df.loc[df['startDate'] > hoje, 'statusVigencia'] = 'Futuro'
        
        print(f"  ✓ Processamento concluído")
        
        return df
    
    def criar_resumo(self, df: pd.DataFrame) -> dict:
        """Cria resumo estatístico dos contratos"""
        
        resumo = {
            'total_contratos': len(df),
            'total_contratos_unicos': df['documentId'].nunique() if 'documentId' in df.columns else 0,
            'valor_total_mao_obra': df['totalLaborValue'].sum(),
            'valor_total_material': df['totalMaterialValue'].sum(),
            'valor_total_geral': df['totalValue'].sum(),
            'media_valor_contrato': df['totalValue'].mean(),
            'contratos_vigentes': len(df[df['statusVigencia'] == 'Vigente']),
            'contratos_vencidos': len(df[df['statusVigencia'] == 'Vencido']),
            'contratos_futuros': len(df[df['statusVigencia'] == 'Futuro']),
        }
        
        # Top fornecedores
        if 'supplierName' in df.columns and not df.empty:
            top_fornecedores = df.groupby('supplierName').agg({
                'totalValue': 'sum',
                'documentId': 'count'
            }).sort_values('totalValue', ascending=False).head(10)
            resumo['top_fornecedores'] = top_fornecedores.to_dict('index')
        
        # Top obras
        if 'buildingName' in df.columns and not df.empty:
            df_com_obra = df[df['buildingName'] != 'SEM OBRA']
            if not df_com_obra.empty:
                top_obras = df_com_obra.groupby('buildingName').agg({
                    'totalValue': 'sum',
                    'documentId': 'count'
                }).sort_values('totalValue', ascending=False).head(10)
                resumo['top_obras'] = top_obras.to_dict('index')
        
        # Distribuição por tipo de contrato
        if 'contractTypeDesc' in df.columns:
            dist_tipo = df.groupby('contractTypeDesc').agg({
                'documentId': 'count',
                'totalValue': 'sum'
            })
            resumo['distribuicao_tipo'] = dist_tipo.to_dict('index')
        
        return resumo
    
    def salvar_resultados(self, df: pd.DataFrame, resumo: dict) -> str:
        """Salva resultados em Excel formatado"""
        from openpyxl import load_workbook
        from openpyxl.worksheet.table import Table, TableStyleInfo
        from openpyxl.utils import get_column_letter
        from openpyxl.styles import Font, PatternFill
        
        timestamp = datetime.now().strftime('%Y%m%d_%H%M%S')
        arquivo = f'Contratos_Fornecimento_Sienge_{timestamp}.xlsx'
        
        # Selecionar colunas para relatório
        colunas_relatorio = [
            'documentId',
            'contractNumber',
            'companyName',
            'supplierName',
            'responsibleName',
            'buildingName',
            'statusApprovalDesc',
            'isAuthorized',
            'statusVigencia',
            'contractDate',
            'startDate',
            'endDate',
            'contratoduracaoDias',
            'contractTypeDesc',
            'registrationTypeDesc',
            'itemTypeDesc',
            'totalLaborValue',
            'totalMaterialValue',
            'totalValue',
            'object',
            'internalNotes',
            'consistent'
        ]
        
        df_relatorio = df[[col for col in colunas_relatorio if col in df.columns]].copy()
        
        # Renomear colunas
        df_relatorio = df_relatorio.rename(columns={
            'documentId': 'ID Documento',
            'contractNumber': 'Nº Contrato',
            'companyName': 'Empresa',
            'supplierName': 'Fornecedor',
            'responsibleName': 'Responsável',
            'buildingName': 'Obra',
            'statusApprovalDesc': 'Status Aprovação',
            'isAuthorized': 'Autorizado',
            'statusVigencia': 'Vigência',
            'contractDate': 'Data Contrato',
            'startDate': 'Início',
            'endDate': 'Fim',
            'contratoduracaoDias': 'Duração (dias)',
            'contractTypeDesc': 'Tipo Contrato',
            'registrationTypeDesc': 'Tipo Registro',
            'itemTypeDesc': 'Tipo Item',
            'totalLaborValue': 'Valor Mão de Obra',
            'totalMaterialValue': 'Valor Material',
            'totalValue': 'Valor Total',
            'object': 'Objeto',
            'internalNotes': 'Observações',
            'consistent': 'Consistente'
        })
        
        # Criar Excel com múltiplas abas
        with pd.ExcelWriter(arquivo, engine='openpyxl') as writer:
            # ABA 1: Contratos
            df_relatorio.to_excel(writer, sheet_name='Contratos', index=False)
            
            # ABA 2: Resumo
            resumo_df = pd.DataFrame([
                ['RESUMO GERAL', ''],
                ['Total de Contratos (linhas)', resumo['total_contratos']],
                ['Contratos Únicos', resumo['total_contratos_unicos']],
                ['Valor Total Mão de Obra', f"R$ {resumo['valor_total_mao_obra']:,.2f}"],
                ['Valor Total Material', f"R$ {resumo['valor_total_material']:,.2f}"],
                ['Valor Total Geral', f"R$ {resumo['valor_total_geral']:,.2f}"],
                ['Valor Médio por Contrato', f"R$ {resumo['media_valor_contrato']:,.2f}"],
                ['', ''],
                ['STATUS DE VIGÊNCIA', ''],
                ['Contratos Vigentes', resumo['contratos_vigentes']],
                ['Contratos Vencidos', resumo['contratos_vencidos']],
                ['Contratos Futuros', resumo['contratos_futuros']],
            ])
            resumo_df.to_excel(writer, sheet_name='Resumo', index=False, header=False)
            
            # ABA 3: Top Fornecedores
            if 'top_fornecedores' in resumo and resumo['top_fornecedores']:
                top_forn_df = pd.DataFrame.from_dict(resumo['top_fornecedores'], orient='index')
                top_forn_df = top_forn_df.rename(columns={
                    'totalValue': 'Valor Total',
                    'documentId': 'Qtd Contratos'
                })
                top_forn_df.index.name = 'Fornecedor'
                top_forn_df.to_excel(writer, sheet_name='Top Fornecedores')
            
            # ABA 4: Top Obras
            if 'top_obras' in resumo and resumo['top_obras']:
                top_obras_df = pd.DataFrame.from_dict(resumo['top_obras'], orient='index')
                top_obras_df = top_obras_df.rename(columns={
                    'totalValue': 'Valor Total',
                    'documentId': 'Qtd Contratos'
                })
                top_obras_df.index.name = 'Obra'
                top_obras_df.to_excel(writer, sheet_name='Top Obras')
        
        # Aplicar formatação
        wb = load_workbook(arquivo)
        
        # Formatar aba "Contratos"
        ws_contratos = wb['Contratos']
        
        if ws_contratos.max_row > 1:
            ultima_coluna = get_column_letter(ws_contratos.max_column)
            ref = f"A1:{ultima_coluna}{ws_contratos.max_row}"
            
            tab = Table(displayName="TabelaContratos", ref=ref)
            style = TableStyleInfo(
                name="TableStyleMedium9",
                showFirstColumn=False,
                showLastColumn=False,
                showRowStripes=True,
                showColumnStripes=False
            )
            tab.tableStyleInfo = style
            ws_contratos.add_table(tab)
            
            # Ajustar larguras
            for column in ws_contratos.columns:
                max_length = 0
                column_letter = get_column_letter(column[0].column)
                for cell in column:
                    try:
                        if cell.value:
                            max_length = max(max_length, len(str(cell.value)))
                    except:
                        pass
                adjusted_width = min(max_length + 2, 60)
                ws_contratos.column_dimensions[column_letter].width = adjusted_width
            
            # Formatar colunas de valores como moeda
            for row in range(2, ws_contratos.max_row + 1):
                for col_letter in ['Q', 'R', 'S']:  # Colunas de valores
                    cell = ws_contratos[f'{col_letter}{row}']
                    if cell.value is not None and isinstance(cell.value, (int, float)):
                        cell.number_format = 'R$ #,##0.00'
            
            ws_contratos.freeze_panes = 'A2'
        
        # Formatar aba "Resumo"
        ws_resumo = wb['Resumo']
        ws_resumo['A1'].font = Font(bold=True, size=14)
        ws_resumo['A1'].fill = PatternFill(start_color="4472C4", end_color="4472C4", fill_type="solid")
        ws_resumo['A1'].font = Font(bold=True, size=14, color="FFFFFF")
        
        ws_resumo['A9'].font = Font(bold=True, size=12)
        ws_resumo['A9'].fill = PatternFill(start_color="4472C4", end_color="4472C4", fill_type="solid")
        ws_resumo['A9'].font = Font(bold=True, size=12, color="FFFFFF")
        
        for row in [2, 3, 4, 5, 6, 7, 10, 11, 12]:
            ws_resumo[f'A{row}'].font = Font(bold=True)
        
        ws_resumo.column_dimensions['A'].width = 40
        ws_resumo.column_dimensions['B'].width = 25
        
        wb.save(arquivo)
        wb.close()
        
        return arquivo


